{
  "name": "merchconnect-mexico",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier -w .",
    "test": "turbo run test",
    "prepare": "husky install",
    "deploy:infra:dev": "cd infra/cdk && STAGE=dev cdk deploy --all --require-approval never",
    "deploy:infra:sbx": "cd infra/cdk && STAGE=sbx cdk deploy --all --require-approval never",
    "deploy:infra:prod": "cd infra/cdk && STAGE=prod cdk deploy --all --require-approval never",
    "synth:infra": "cd infra/cdk && cdk synth",
    "seed:dev": "tsx scripts/seed-dev.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "turbo": "^2.0.6",
    "tsx": "^4.16.2",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,css,scss}": [
      "prettier -w"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
